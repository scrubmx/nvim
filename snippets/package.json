{
  "name": "friendly-snippets",
  "engines": {
    "vscode": "^1.11.0"
  },
  "contributes": {
    "snippets": [
      {
        "language": [
          "plaintext",
          "markdown",
          "html",
          "global",
          "all"
        ],
        "path": "./global.json"
      },
      {
        "language": "elixir",
        "path": "./elixir/elixir.json"
      },
      {
        "language": [
          "eelixir",
          "heex"
        ],
        "path": "./elixir/eelixir.json"
      },
      {
        "language": "gleam",
        "path": "./gleam.json"
      },
      {
        "language": "lua",
        "path": "./lua/lua.json"
      },
      {
        "language": "luadoc",
        "path": "./lua/luadoc.json"
      },
      {
        "language": "php",
        "path": "./php/php.json"
      },
      {
        "language": "phpdoc",
        "path": "./php/phpdoc.json"
      },
      {
        "language": "norg",
        "path": "./norg.json"
      },
      {
        "language": [
          "html",
          "jade",
          "pug",
          "eruby",
          "javascriptreact",
          "htmldjango",
          "astro",
          "blade"
        ],
        "path": "./html.json"
      },
      {
        "language": [
          "javascript",
          "javascriptreact",
          "vue",
          "svelte"
        ],
        "path": "./javascript/javascript.json"
      },
      {
        "language": "jsdoc",
        "path": "./javascript/jsdoc.json"
      },
      {
        "language": "tsdoc",
        "path": "./javascript/tsdoc.json"
      },
      {
        "language": [
          "typescript",
          "typescriptreact"
        ],
        "path": "./javascript/typescript.json"
      },
      {
        "language": "javascriptreact",
        "path": "./javascript/next.json"
      },
      {
        "language": "typescriptreact",
        "path": "./javascript/next-ts.json"
      },
      {
        "language": "javascriptreact",
        "path": "./javascript/react.json"
      },
      {
        "language": "typescriptreact",
        "path": "./javascript/react-ts.json"
      },
      {
        "language": "javascriptreact",
        "path": "./javascript/react-native.json"
      },
      {
        "language": "typescriptreact",
        "path": "./javascript/react-native-ts.json"
      },
      {
        "language": [
          "javascriptreact",
          "typescriptreact"
        ],
        "path": "./javascript/react-es7.json"
      }
    ]
  }
}
